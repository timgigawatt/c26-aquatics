---
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import StatsBand from '@components/sections/StatsBand.astro';
import MissionBand from '@components/sections/MissionBand.astro';
import DifferenceMatrix from '@components/sections/DifferenceMatrix.astro';
import TracksLadder from '@components/sections/TracksLadder.astro';
import SeamHatch from '@components/ui/SeamHatch.astro';
import SeamAngle from '@components/ui/SeamAngle.astro';
import CoachesGrid from '@components/sections/CoachesGrid.astro';
import TestimonialsBand from '@components/sections/TestimonialsBand.astro';
import LocationBand from '@components/sections/LocationBand.astro';
import ServiceAreaBand from '@components/sections/ServiceAreaBand.astro';
import FAQAccordion from '@components/sections/FAQAccordion.astro';
import CTABand from '@components/sections/CTABand.astro';
import { sportsOrganizationSchema, jsonLd } from '@lib/schemas';
import { site } from '@data/site';
import { publicPhoto } from '@lib/photos';
import { mission, coachingSystem } from '@data/approach';

const orgSchema = sportsOrganizationSchema();
---
<Base
  title="C26 Aquatics — Competitive Swim Team in Kansas City"
  description="C26 Aquatics is a Kansas City–metro competitive swim team — one pool, one coaching staff, one standard. Training groups from developmental to elite."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="home"
      title="Become a <span class=&quot;hero-accent-magenta&quot;>stronger</span> swimmer"
      subtitle="Competitive swim training in the Kansas City metro — one pool, one coaching staff, one standard."
      primaryCta={{ label: 'Join the Team', href: site.booking.team, external: true }}
      secondaryCta={{ label: 'Explore training groups', href: '#tracks' }}
    />

    <StatsBand />

    <MissionBand
      eyebrow="Our mission"
      heading="Coach the person first, the swimmer second"
      paragraphs={[
        mission,
        'We prioritize relationships, consistency, and intentional progress — building confident, resilient young people who learn discipline, accountability, and a love for the process.',
      ]}
      cta={{ label: 'Read our story', href: '/our-story' }}
      image={publicPhoto('/photos/founders')}
    />

    <DifferenceMatrix
      condensed
      cta={{ label: 'See the full comparison', href: '/our-approach#difference' }}
    >
      <div slot="after-rows" class="coach-teaser">
        <p class="coach-teaser__line">Six things every C26 practice includes — from every coach, in every group.</p>
        <ul class="coach-teaser__words" aria-label="The C26 coaching system">
          {coachingSystem.map((c) => (
            <li class="coach-teaser__word">{c.title}</li>
          ))}
        </ul>
        <a class="coach-teaser__cta" href="/our-approach/#coaching-system">
          See how we coach
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </DifferenceMatrix>

    <TracksLadder />

    <SeamHatch />
    <CoachesGrid
      columns={4}
      watermark="left"
      eyebrow="The staff"
      heading="Coaches & bios"
      subtitle="Professional coaches building swimmers across the KC metro."
    />

    <TestimonialsBand variant="feature" featuredOnly={true} />
    <SeamAngle color="var(--navy-700)" />

    <LocationBand image={publicPhoto('/photos/facility-exterior')} />

    <ServiceAreaBand />

    <FAQAccordion surface="home" heading="Frequently asked" />

    <SeamHatch />
    <CTABand
      title="Get in the <span class='hero-accent accent'>water</span>"
      watermark="right"
      primaryCta={{ label: 'Join the Team', href: site.booking.team, external: true }}
      secondaryCta={{ label: 'Read our approach', href: '/our-approach' }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

<style>
  /* Coaching-system teaser inside the Why C26 section */
  .coach-teaser {
    margin-top: var(--space-8);
  }
  .coach-teaser__line {
    font-size: 16px;
    line-height: 1.55;
    color: var(--text-body);
    margin: 0 0 var(--space-4);
  }
  .coach-teaser__words {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .coach-teaser__word {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 13px;
    color: var(--teal-700);
    background: var(--surface);
    border: 1px solid var(--teal-400);
    border-radius: var(--r-pill);
    padding: 8px 18px;
  }
  .coach-teaser__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition:
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }
  .coach-teaser__cta:hover {
    color: var(--navy-700);
    border-bottom-color: var(--teal-500);
  }
</style>

