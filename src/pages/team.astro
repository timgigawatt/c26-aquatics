---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';
import { micromark } from 'micromark';
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import FAQAccordion from '@components/sections/FAQAccordion.astro';
import CTABand from '@components/sections/CTABand.astro';
import TrackTabs from '@components/widgets/TrackTabs.astro';
import TrainingGroupsTable from '@components/widgets/TrainingGroupsTable.astro';
import TeamEvaluations from '@components/sections/TeamEvaluations.astro';
import StatBlock from '@components/ui/StatBlock.astro';
import { site } from '@data/site';
import {
  sportsOrganizationSchema,
  sportsTeamSchema,
  jsonLd,
} from '@lib/schemas';

type GroupEntry = CollectionEntry<'training-groups'>;
type CoachEntry = CollectionEntry<'coaches'>;

const orgSchema = sportsOrganizationSchema();
const teamSchema = sportsTeamSchema();

const groups = (await getCollection('training-groups')).sort(
  (a: GroupEntry, b: GroupEntry) => a.data.order - b.data.order,
);

const usd = (n: number) => (n % 1 === 0 ? `$${n}` : `$${n.toFixed(2)}`);

// Reverse the coach → groups relation: each track lists the coaches whose
// frontmatter references it, sorted by coach `order` (head coach first).
const allCoaches = (await getCollection('coaches')).sort(
  (a: CoachEntry, b: CoachEntry) => a.data.order - b.data.order,
);

const initialsOf = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word[0])
    .join('')
    .toUpperCase();

const coachesForGroup = (slug: string) =>
  allCoaches
    .filter((coach: CoachEntry) =>
      coach.data.groups.some((ref) => ref.slug === slug),
    )
    .map((coach: CoachEntry) => ({
      slug: coach.slug,
      name: coach.data.name,
      role: coach.data.role,
      headshot: coach.data.headshot,
      hasHeadshot: fs.existsSync(
        path.join(process.cwd(), 'public', coach.data.headshot),
      ),
      initials: initialsOf(coach.data.name),
    }));

const tracks = groups.map((entry: GroupEntry) => ({
  slug: entry.slug,
  name: entry.data.name,
  eyebrowText: entry.data.ageRange,
  bodyHtml: micromark(entry.body),
  meta: [
    { label: 'Ages', value: entry.data.ageRange },
    { label: 'Group size', value: `${entry.data.groupSize}` },
    { label: 'Practices', value: entry.data.suggestedPractices },
    { label: 'Hrs/mo', value: `${entry.data.monthlyHours}` },
    { label: 'Monthly', value: usd(entry.data.monthlyCost) },
    { label: 'Per hour', value: usd(entry.data.costPerHour) },
  ],
  scheduleOptions: entry.data.scheduleOptions,
  coaches: coachesForGroup(entry.slug),
}));

const compareRows = groups.map((entry: GroupEntry) => ({
  slug: entry.slug,
  name: entry.data.name,
  ageRange: entry.data.ageRange,
  groupSize: entry.data.groupSize,
  suggestedPractices: entry.data.suggestedPractices,
  monthlyHours: entry.data.monthlyHours,
  monthlyCost: entry.data.monthlyCost,
  costPerHour: entry.data.costPerHour,
  commitmentLevel: entry.data.commitmentLevel,
}));
---
<Base
  title="Competitive Swim Team | C26 Aquatics"
  description="Train with C26 Aquatics — USA Swimming–registered competitive training groups for KC-metro athletes from developmental to elite. Find your training group."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
    <script type="application/ld+json" set:html={jsonLd(teamSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="page"
      eyebrow="Competitive team"
      title="Train. Compete. <span class='hero-accent'>Improve.</span>"
      subtitle="USA Swimming–registered training groups for committed athletes — Pre-Competitive through Senior Elite."
      primaryCta={{ label: 'Join the Team', href: site.booking.team, external: true }}
    />

    <TrackTabs
      id="team-tabs"
      eyebrow="Training groups"
      heading="Find your training group"
      subtitle="Seven groups, calibrated by age and ability — every swimmer placed by coach evaluation."
      tracks={tracks}
    />

    <TrainingGroupsTable
      eyebrow="At a glance"
      heading="Compare the groups"
      subtitle="Every group side by side — ages, schedule load, and cost per pool hour."
      rows={compareRows}
    />

    <section class="philosophy" aria-labelledby="philosophy-title">
      <div class="container philosophy__inner">
        <header class="philosophy__head">
          <p class="philosophy__eyebrow">Why C26</p>
          <h2 id="philosophy-title" class="philosophy__heading">
            Coached by professionals. Built for the long run.
          </h2>
          <p class="philosophy__lede">
            Every group is led by a USA Swimming–registered, SafeSport-certified
            coach. We chase consistency over hype — measured progress, season after season.
          </p>
        </header>
        <div class="philosophy__stats">
          <StatBlock value="7" label="Training groups" accent="orange" tone="light" align="left" />
          <StatBlock value="100%" label="SafeSport-certified coaches" accent="teal" tone="light" align="left" />
          <StatBlock value="6+" label="KC-metro communities served" accent="navy" tone="light" align="left" />
        </div>
      </div>
    </section>

    <TeamEvaluations />

    <FAQAccordion surface="team" heading="Team FAQs" />

    <CTABand
      title="Ready to <span class='hero-accent accent'>join the team?</span>"
      primaryCta={{ label: 'Join the Team', href: site.booking.team, external: true }}
      secondaryCta={{ label: 'Meet the coaches', href: '/coaches' }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

<style>
  .philosophy {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .philosophy__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: center;
  }
  .philosophy__head {
    max-width: 520px;
  }
  .philosophy__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .philosophy__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.4vw, 38px);
    color: var(--navy-700);
    margin: 0;
  }
  .philosophy__lede {
    margin: var(--space-4) 0 0;
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-body);
  }
  .philosophy__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-8);
    background: var(--surface);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 800px) {
    .philosophy__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
