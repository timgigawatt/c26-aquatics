---
/**
 * TrackTabs — accessible, JS-toggled tabs used on /team and /swim-lessons.
 *
 * Crawlability: every tab panel is rendered in the DOM at build time. JS only
 * toggles `hidden`/`aria-hidden`/`aria-selected` and tabindex — content is
 * always present for crawlers and JS-disabled visitors.
 *
 * Keyboard: ArrowLeft/Right move focus through tabs, Home/End jump to ends,
 * Enter/Space activates. Roving tabindex (only the active tab is tabbable).
 *
 * Pure UI primitive — callers shape collection entries into the `tracks` prop;
 * the widget never touches `astro:content`.
 */
interface MetaItem {
  label: string;
  value: string;
}

interface ScheduleSlot {
  day: string;
  time: string;
}

interface ScheduleOption {
  label?: string;
  slots: ScheduleSlot[];
}

interface TrackCoach {
  slug: string;
  name: string;
  role: string;
  headshot: string;
  hasHeadshot: boolean;
  initials: string;
}

interface Track {
  slug: string;
  name: string;
  eyebrowText?: string;
  bodyHtml: string;
  meta?: MetaItem[];
  scheduleOptions?: ScheduleOption[];
  coaches?: TrackCoach[];
}

interface Props {
  id: string;
  eyebrow?: string;
  heading: string;
  subtitle?: string;
  tracks: Track[];
}

const { id, eyebrow, heading, subtitle, tracks } = Astro.props;
const safeId = id.replace(/[^a-zA-Z0-9_-]/g, '-');
---
<section class="tracks" aria-labelledby={`${safeId}-title`}>
  <div class="container">
    <header class="tracks__head">
      {eyebrow && <p class="tracks__eyebrow">{eyebrow}</p>}
      <h2 id={`${safeId}-title`} class="tracks__heading">{heading}</h2>
      {subtitle && <p class="tracks__subtitle">{subtitle}</p>}
    </header>

    <div class="tracks__widget" data-track-tabs id={safeId}>
      <div role="tablist" aria-label={heading} class="tracks__tablist">
        {tracks.map((track, i) => (
          <button
            type="button"
            role="tab"
            id={`${safeId}-tab-${track.slug}`}
            class="tracks__tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`${safeId}-panel-${track.slug}`}
            tabindex={i === 0 ? 0 : -1}
            data-tab={track.slug}
          >
            {track.eyebrowText && (
              <span class="tracks__tab-eyebrow">{track.eyebrowText}</span>
            )}
            <span class="tracks__tab-name">{track.name}</span>
          </button>
        ))}
      </div>

      <div class="tracks__panels">
        {tracks.map((track, i) => (
          <div
            role="tabpanel"
            id={`${safeId}-panel-${track.slug}`}
            aria-labelledby={`${safeId}-tab-${track.slug}`}
            class="tracks__panel"
            hidden={i !== 0}
            aria-hidden={i !== 0 ? 'true' : 'false'}
            tabindex="0"
            data-panel={track.slug}
          >
            {track.meta && track.meta.length > 0 && (
              <dl class="tracks__meta">
                {track.meta.map((m) => (
                  <div class="tracks__meta-item">
                    <dt>{m.label}</dt>
                    <dd>{m.value}</dd>
                  </div>
                ))}
              </dl>
            )}
            {track.scheduleOptions && track.scheduleOptions.length > 0 && (
              <div class="tracks__schedule" data-schedule>
                <p class="tracks__schedule-label">Weekly schedule</p>
                {track.scheduleOptions.length > 1 && (
                  <div class="tracks__sched-toggle" role="tablist" aria-label="Schedule options">
                    {track.scheduleOptions.map((opt, oi) => (
                      <button
                        type="button"
                        role="tab"
                        class="tracks__sched-tab"
                        aria-selected={oi === 0 ? 'true' : 'false'}
                        tabindex={oi === 0 ? 0 : -1}
                        data-sched-tab={oi}
                      >
                        {opt.label ?? `Option ${oi + 1}`}
                      </button>
                    ))}
                  </div>
                )}
                {track.scheduleOptions.map((opt, oi) => (
                  <ul
                    class="tracks__slots"
                    data-sched-panel={oi}
                    hidden={oi !== 0}
                  >
                    {opt.slots.map((slot) => (
                      <li class="tracks__slot">
                        <span class="tracks__slot-day">{slot.day}</span>
                        <span class="tracks__slot-time">{slot.time}</span>
                      </li>
                    ))}
                  </ul>
                ))}
              </div>
            )}
            <div class="tracks__body" set:html={track.bodyHtml}></div>
            {track.coaches && track.coaches.length > 0 && (
              <div class="tracks__coaches">
                <p class="tracks__coaches-label">Coached by</p>
                <ul class="tracks__coaches-list">
                  {track.coaches.map((coach) => (
                    <li>
                      <a class="tracks__coach" href={`/coaches#${coach.slug}`}>
                        {coach.hasHeadshot ? (
                          <img
                            class="tracks__coach-photo"
                            src={coach.headshot}
                            alt=""
                            width="40"
                            height="40"
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <span class="tracks__coach-photo tracks__coach-initials" aria-hidden="true">
                            {coach.initials}
                          </span>
                        )}
                        <span class="tracks__coach-ident">
                          <span class="tracks__coach-name">{coach.name}</span>
                          <span class="tracks__coach-role">{coach.role}</span>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  /* eslint-disable */
  function initTrackTabs(root: HTMLElement) {
    // [data-tab] keeps the schedule Option 1/2 sub-toggle (also role="tab")
    // out of this tablist — matching it here clobbered its selected state.
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>('[role="tab"][data-tab]'),
    );
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>('[role="tabpanel"]'),
    );

    function activate(slug: string, focusTab: boolean) {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.tab === slug;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (isActive && focusTab) tab.focus();
      });
      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === slug;
        panel.hidden = !isActive;
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        const slug = tab.dataset.tab;
        if (slug) activate(slug, false);
      });

      tab.addEventListener('keydown', (event: KeyboardEvent) => {
        let nextIndex: number | null = null;
        switch (event.key) {
          case 'ArrowRight':
            nextIndex = (index + 1) % tabs.length;
            break;
          case 'ArrowLeft':
            nextIndex = (index - 1 + tabs.length) % tabs.length;
            break;
          case 'Home':
            nextIndex = 0;
            break;
          case 'End':
            nextIndex = tabs.length - 1;
            break;
          case 'Enter':
          case ' ': {
            const slug = tab.dataset.tab;
            if (slug) activate(slug, false);
            event.preventDefault();
            return;
          }
          default:
            return;
        }
        event.preventDefault();
        if (nextIndex !== null) {
          const slug = tabs[nextIndex].dataset.tab;
          if (slug) activate(slug, true);
        }
      });
    });

    // Deep-link support: /team#<slug> activates that tab. Panels have
    // prefixed ids, so the browser never scrolls natively — we do both.
    function activateFromHash(scroll: boolean) {
      const slug = decodeURIComponent(window.location.hash.slice(1));
      if (!slug || !tabs.some((tab) => tab.dataset.tab === slug)) return;
      activate(slug, false);
      if (scroll) root.scrollIntoView({ block: 'start' });
    }
    activateFromHash(window.location.hash.length > 1);
    window.addEventListener('hashchange', () => activateFromHash(true));
  }

  document
    .querySelectorAll<HTMLElement>('[data-track-tabs]')
    .forEach((el) => initTrackTabs(el));

  // Schedule Option 1 / Option 2 sub-toggle, scoped to each panel that has one.
  function initSchedule(root: HTMLElement) {
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>('[data-sched-tab]'),
    );
    const panels = Array.from(
      root.querySelectorAll<HTMLElement>('[data-sched-panel]'),
    );
    if (tabs.length === 0) return;

    function show(index: number) {
      tabs.forEach((tab, i) => {
        const isActive = i === index;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
      });
      panels.forEach((panel) => {
        const isActive = Number(panel.dataset.schedPanel) === index;
        panel.hidden = !isActive;
      });
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => show(index));
      tab.addEventListener('keydown', (event: KeyboardEvent) => {
        let next: number | null = null;
        if (event.key === 'ArrowRight') next = (index + 1) % tabs.length;
        else if (event.key === 'ArrowLeft')
          next = (index - 1 + tabs.length) % tabs.length;
        else return;
        event.preventDefault();
        show(next);
        tabs[next].focus();
      });
    });
  }

  document
    .querySelectorAll<HTMLElement>('[data-schedule]')
    .forEach((el) => initSchedule(el));
</script>

<style>
  .tracks {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .tracks__head {
    max-width: 720px;
    margin-bottom: var(--space-10);
  }
  .tracks__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .tracks__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    color: var(--navy-700);
    margin: 0;
  }
  .tracks__subtitle {
    margin: var(--space-3) 0 0;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-body);
  }

  .tracks__widget {
    scroll-margin-top: 96px;
  }

  .tracks__tablist {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-8);
  }

  .tracks__tab {
    background: transparent;
    border: 0;
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -1px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    transition:
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }
  .tracks__tab:hover {
    color: var(--navy-700);
  }
  .tracks__tab[aria-selected='true'] {
    color: var(--navy-700);
    border-bottom-color: var(--orange-500);
  }
  .tracks__tab-eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    font-size: 11px;
    letter-spacing: var(--ls-eyebrow);
    color: var(--teal-600);
  }
  .tracks__tab-name {
    font-size: 18px;
    line-height: 1.1;
  }

  .tracks__panel {
    background: var(--surface-alt);
    border-radius: var(--r-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .tracks__panel[hidden] { display: none; }
  .tracks__panel:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 2px;
  }

  .tracks__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: var(--space-4) var(--space-5);
    background: var(--surface);
    border-radius: var(--r-md);
    border: 1px solid var(--border);
  }
  .tracks__meta-item {
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .tracks__meta dt {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 11px;
    color: var(--teal-700);
    margin: 0;
  }
  .tracks__meta dd {
    margin: 0;
    font-size: 14px;
    color: var(--text-strong);
    font-weight: var(--fw-medium);
  }

  /* ----- weekly schedule + Option 1 / Option 2 toggle ----- */
  .tracks__schedule {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .tracks__schedule-label {
    margin: 0;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 11px;
    color: var(--teal-700);
  }
  .tracks__sched-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    align-self: flex-start;
  }
  .tracks__sched-tab {
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--r-pill);
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
    color: var(--text-muted);
    transition:
      background var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }
  .tracks__sched-tab[aria-selected='true'] {
    background: var(--navy-700);
    color: var(--white);
  }
  .tracks__slots {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-2);
  }
  .tracks__slots[hidden] { display: none; }
  .tracks__slot {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
  }
  .tracks__slot-day {
    flex: none;
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
    color: var(--navy-700);
    min-width: 30px;
  }
  .tracks__slot-time {
    font-size: 13px;
    color: var(--text-body);
  }

  /* ----- "Coached by" row linking to /coaches#<slug> ----- */
  .tracks__coaches {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .tracks__coaches-label {
    margin: 0;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 11px;
    color: var(--teal-700);
  }
  .tracks__coaches-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .tracks__coach {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-4) var(--space-2) var(--space-2);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    text-decoration: none;
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .tracks__coach:hover {
    border-color: var(--teal-500);
  }
  .tracks__coach:focus-visible {
    outline: 2px solid var(--teal-500);
    outline-offset: 2px;
  }
  .tracks__coach-photo {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tracks__coach-initials {
    background: linear-gradient(135deg, var(--navy-700) 0%, var(--navy-800) 100%);
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: 14px;
    color: var(--teal-400);
    user-select: none;
  }
  .tracks__coach-ident {
    display: flex;
    flex-direction: column;
  }
  .tracks__coach-name {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    font-size: 14px;
    color: var(--navy-700);
    line-height: 1.2;
  }
  .tracks__coach-role {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .tracks__body {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-body);
  }
  .tracks__body :global(h2),
  .tracks__body :global(h3),
  .tracks__body :global(h4) {
    font-family: var(--font-display);
    color: var(--navy-700);
    text-transform: uppercase;
    margin: var(--space-5) 0 var(--space-2);
  }
  .tracks__body :global(h2) { font-size: 26px; }
  .tracks__body :global(h3) { font-size: 22px; }
  .tracks__body :global(h4) { font-size: 18px; }
  .tracks__body :global(p) { margin: 0 0 var(--space-3); }
  .tracks__body :global(ul),
  .tracks__body :global(ol) {
    margin: 0 0 var(--space-3);
    padding-left: var(--space-5);
  }
  .tracks__body :global(li) { margin-bottom: var(--space-2); }
  .tracks__body :global(strong) { color: var(--text-strong); }

  @media (max-width: 600px) {
    .tracks__panel { padding: var(--space-5); }
    .tracks__tab { padding: var(--space-3) var(--space-4); }
    .tracks__tab-name { font-size: 16px; }
  }
</style>
