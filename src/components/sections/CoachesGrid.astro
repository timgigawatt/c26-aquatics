---
/**
 * CoachesGrid — responsive grid of coach cards.
 * Fetches the `coaches` collection, sorts by `order`, slices to `limit`.
 * Each card has an id matching the entry slug so `/coaches#robbie-bruce` works.
 *
 * Headshots are runtime path strings (under /public), not bundled assets — we
 * render with a plain <img> with explicit width/height to prevent CLS.
 */
import fs from 'node:fs';
import path from 'node:path';
import { getCollection, getEntries, type CollectionEntry } from 'astro:content';
import Card from '@components/ui/Card.astro';
import Badge from '@components/ui/Badge.astro';
import krakenWhite from '@assets/brand/kraken-white.svg';
import krakenGradient from '@assets/brand/kraken-gradient.svg';

interface Props {
  limit?: number;
  eyebrow?: string;
  heading?: string;
  subtitle?: string;
  tone?: 'light' | 'dark';
  /** Compact cards: chrome-less photo + name + role only (no badges/bio).
   *  Used on the homepage to keep the section short. */
  compact?: boolean;
  /** Oversized kraken watermark bleeding off the named edge (dark tone only). */
  watermark?: 'left' | 'right';
  /** Optional "see more" link rendered inside the section, after the grid. */
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  limit,
  eyebrow = 'The staff',
  heading = 'Coaches & bios',
  subtitle,
  tone = 'dark',
  compact = false,
  watermark,
  ctaLabel,
  ctaHref,
} = Astro.props;

type CoachEntry = CollectionEntry<'coaches'>;
const all = await getCollection('coaches');
const sorted = all.sort(
  (a: CoachEntry, b: CoachEntry) => a.data.order - b.data.order,
);
const coaches = typeof limit === 'number' ? sorted.slice(0, limit) : sorted;

// Headshots are placeholders until real photos land in /public/coaches. Check
// at build time so we render the gradient kraken on dark ("Kraken · dark"
// from /variations) with the coach's initials in front, instead of a broken <img>.
const initialsOf = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word[0])
    .join('')
    .toUpperCase();

const rendered = await Promise.all(
  coaches.map(async (coach: CoachEntry) => {
    const { Content } = await coach.render();
    const hasHeadshot = fs.existsSync(
      path.join(process.cwd(), 'public', coach.data.headshot),
    );
    // Resolve group references (frontmatter order preserved) so chips show the
    // group's real name and link to its tab on /team.
    const groups = (await getEntries(coach.data.groups)).map((entry) => ({
      name: entry.data.name,
      href: `/team#${entry.slug}`,
    }));
    return { coach, Content, groups, hasHeadshot, initials: initialsOf(coach.data.name) };
  }),
);
---
<section
  class:list={['coaches', `coaches--${tone}`, { 'coaches--watermarked': watermark }]}
  aria-labelledby="coaches-title"
>
  {watermark && (
    <img
      src={krakenWhite.src}
      alt=""
      aria-hidden="true"
      class:list={['coaches__watermark', `coaches__watermark--${watermark}`]}
      loading="lazy"
    />
  )}
  <div class="container">
    <header class="coaches__head">
      {eyebrow && <p class="coaches__eyebrow">{eyebrow}</p>}
      <h2 id="coaches-title" class="coaches__heading">{heading}</h2>
      {subtitle && <p class="coaches__subtitle">{subtitle}</p>}
    </header>

    <div class="coaches__grid">
      {rendered.map(({ coach, groups, hasHeadshot, initials }) => (
        <article id={coach.slug} class:list={['coach-card', { 'coach-card--compact': compact }]}>
          <div class="coach-card__media">
            {hasHeadshot ? (
              <img
                src={coach.data.headshot}
                alt={`${coach.data.name}, ${coach.data.role}`}
                width="600"
                height="600"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="coach-card__placeholder" aria-hidden="true">
                <img src={krakenGradient.src} alt="" loading="lazy" decoding="async" />
                <span class="coach-card__initials">{initials}</span>
              </div>
            )}
          </div>
          <div class="coach-card__body">
            <h3 class="coach-card__name">{coach.data.name}</h3>
            <div class="coach-card__role">{coach.data.role}</div>
            {!compact && coach.data.tagline && (
              <p class="coach-card__tagline">{coach.data.tagline}</p>
            )}
            {!compact && (groups.length > 0 || coach.data.programs.length > 0) && (
              <div class="coach-card__facts">
                {groups.map((group) => (
                  <a class="coach-chip" href={group.href}>{group.name}</a>
                ))}
                {coach.data.programs.map((program) => (
                  <Badge tone="teal" size="sm">{program}</Badge>
                ))}
              </div>
            )}
            {!compact && (
              <button
                type="button"
                class="coach-card__more"
                data-coach-open={coach.slug}
                aria-haspopup="dialog"
                aria-controls={`bio-${coach.slug}`}
              >
                Full bio
                <span aria-hidden="true">&rarr;</span>
              </button>
            )}
          </div>
        </article>
      ))}
    </div>

    {!compact && rendered.map(({ coach, Content, groups, hasHeadshot, initials }) => (
      <dialog id={`bio-${coach.slug}`} class="coach-dialog" aria-labelledby={`bio-${coach.slug}-name`}>
        <div class="coach-dialog__inner">
          <button
            type="button"
            class="coach-dialog__close"
            data-coach-close
            aria-label={`Close ${coach.data.name}'s bio`}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
          <div class="coach-dialog__header">
            <div class="coach-dialog__media">
              {hasHeadshot ? (
                <img src={coach.data.headshot} alt={`${coach.data.name}, ${coach.data.role}`} width="200" height="200" />
              ) : (
                <div class="coach-dialog__placeholder" aria-hidden="true">
                  <img src={krakenGradient.src} alt="" loading="lazy" decoding="async" />
                  <span class="coach-card__initials">{initials}</span>
                </div>
              )}
            </div>
            <div class="coach-dialog__ident">
              <h3 id={`bio-${coach.slug}-name`} class="coach-dialog__name">{coach.data.name}</h3>
              <div class="coach-dialog__role">{coach.data.role}</div>
              <div class="coach-dialog__badges">
                {coach.data.usaSwimmingMember && (
                  <Badge tone="teal" size="sm">USA Swimming</Badge>
                )}
                {coach.data.safeSportCertified && (
                  <Badge tone="orange" size="sm">SafeSport Certified</Badge>
                )}
              </div>
            </div>
          </div>

          <div class="coach-dialog__body">
            {(groups.length > 0 || coach.data.programs.length > 0) && (
              <div class="coach-dialog__facts">
                <h4 class="coach-dialog__facts-title">Groups &amp; programs</h4>
                <div class="coach-card__facts">
                  {groups.map((group) => (
                    <a class="coach-chip" href={group.href}>{group.name}</a>
                  ))}
                  {coach.data.programs.map((program) => (
                    <Badge tone="teal" size="sm">{program}</Badge>
                  ))}
                </div>
              </div>
            )}
            <div class="coach-dialog__bio">
              <Content />
            </div>
            {coach.data.highlights.length > 0 && (
              <div class="coach-dialog__highlights">
                <h4 class="coach-dialog__highlights-title">Career highlights</h4>
                <ul class="coach-dialog__highlights-list">
                  {coach.data.highlights.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </dialog>
    ))}

    {ctaLabel && ctaHref && (
      <div class="coaches__cta">
        <a href={ctaHref} class="coaches__cta-link">
          {ctaLabel}
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    )}
  </div>
</section>

<script>
  // Wire coach cards to their bio <dialog>. Native <dialog>.showModal() gives us
  // focus trapping, Esc-to-close, and a ::backdrop for free — we only add the
  // open triggers, backdrop-click dismissal, and body scroll lock.
  const openers = document.querySelectorAll<HTMLButtonElement>('[data-coach-open]');
  openers.forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.getAttribute('data-coach-open');
      const dialog = document.getElementById(`bio-${slug}`) as HTMLDialogElement | null;
      if (!dialog?.showModal) return;
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    });
  });

  document.querySelectorAll<HTMLDialogElement>('dialog.coach-dialog').forEach((dialog) => {
    const restore = () => {
      document.body.style.overflow = '';
    };
    dialog.addEventListener('close', restore);
    // Close button
    dialog
      .querySelector('[data-coach-close]')
      ?.addEventListener('click', () => dialog.close());
    // Click on the backdrop (outside the inner panel) closes the dialog
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .coaches {
    padding: var(--section-y) 0;
  }
  .coaches--dark {
    background: var(--navy-900);
    color: var(--text-on-dark);
  }
  .coaches--light {
    background: var(--surface);
    color: var(--text-body);
  }

  /* Oversized kraken watermark bleeding off-edge at very low opacity. */
  .coaches--watermarked {
    position: relative;
    overflow: hidden;
  }
  .coaches--watermarked .container {
    position: relative;
    z-index: 1;
  }
  .coaches__watermark {
    position: absolute;
    bottom: -12%;
    width: clamp(360px, 48vw, 620px);
    height: auto;
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .coaches__watermark--left { left: -8%; }
  .coaches__watermark--right { right: -8%; }

  .coaches__head {
    max-width: 720px;
    margin-bottom: var(--space-10);
  }
  .coaches__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    margin: 0 0 var(--space-2);
  }
  .coaches--dark .coaches__eyebrow { color: var(--teal-400); }
  .coaches--light .coaches__eyebrow { color: var(--teal-600); }

  .coaches__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    margin: 0;
  }
  .coaches--dark .coaches__heading { color: var(--white); }
  .coaches--light .coaches__heading { color: var(--navy-700); }

  .coaches__subtitle {
    margin: var(--space-3) 0 0;
    font-size: 18px;
    line-height: 1.55;
  }
  .coaches--dark .coaches__subtitle { color: var(--text-on-dark-muted); }

  .coaches__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .coach-card {
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    scroll-margin-top: 96px;
  }
  .coaches--dark .coach-card {
    background: var(--navy-800);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .coach-card__media {
    aspect-ratio: 1 / 1;
    background: var(--mist);
    overflow: hidden;
  }
  .coaches--dark .coach-card__media {
    background: var(--navy-700);
  }
  .coach-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Branded fallback when a headshot file is missing — the gradient kraken
   * on navy-900 ("Kraken · dark" from /variations) with the coach's
   * initials in front, on both section tones. */
  .coach-card__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy-900);
  }
  .coach-card__placeholder img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    opacity: 0.55; /* recede behind the initials */
  }
  .coach-card__initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: clamp(40px, 6vw, 64px);
    letter-spacing: var(--ls-tight);
    color: var(--white);
    text-shadow: 0 2px 18px rgba(14, 19, 48, 0.85);
    user-select: none;
  }

  .coach-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1 1 auto;
  }
  .coach-card__name {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: 24px;
    margin: 0;
  }
  .coaches--dark .coach-card__name { color: var(--white); }
  .coaches--light .coach-card__name { color: var(--navy-700); }

  .coach-card__role {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 13px;
  }
  .coaches--dark .coach-card__role { color: var(--teal-400); }
  .coaches--light .coach-card__role { color: var(--teal-700); }

  /* Personality hook on the card face */
  .coach-card__tagline {
    margin: var(--space-1) 0 0;
    font-size: 15px;
    line-height: 1.5;
  }
  .coaches--dark .coach-card__tagline { color: var(--text-on-dark-muted); }
  .coaches--light .coach-card__tagline { color: var(--text-body); }

  /* Scannable groups + programs chips */
  .coach-card__facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Group chip — a link to the group's tab on /team, styled to sit beside the
   * Badge program chips. Base style is for light surfaces (dialog, light tone);
   * dark cards get an outline-light override below. */
  .coach-chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 11px;
    padding: 3px 9px;
    border-radius: var(--r-pill);
    white-space: nowrap;
    background: var(--surface-inset);
    color: var(--text-body);
    border: 1px solid var(--border);
    text-decoration: none;
    transition:
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }
  .coach-chip:hover {
    color: var(--teal-700);
    border-color: var(--teal-500);
  }
  .coach-chip:focus-visible {
    outline: 2px solid var(--teal-500);
    outline-offset: 2px;
  }
  .coaches--dark .coach-card .coach-chip {
    background: transparent;
    color: var(--text-on-dark-muted);
    border-color: var(--border-on-dark);
  }
  .coaches--dark .coach-card .coach-chip:hover {
    color: var(--white);
    border-color: var(--teal-400);
  }

  /* "Groups & programs" row at the top of the bio dialog */
  .coach-dialog__facts {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--border);
  }
  .coach-dialog__facts-title {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 13px;
    color: var(--teal-700);
    margin: 0 0 var(--space-3);
  }

  /* "Full bio" trigger — sits at the card foot, pushed down so cards align */
  .coach-card__more {
    margin-top: auto;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    padding: var(--space-1) 0 0;
    cursor: pointer;
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 13px;
    transition: gap var(--dur-base) var(--ease-out), color var(--dur-base) var(--ease-out);
  }
  .coaches--dark .coach-card__more { color: var(--teal-400); }
  .coaches--light .coach-card__more { color: var(--teal-700); }
  .coach-card__more:hover { gap: var(--space-3); }
  .coaches--dark .coach-card__more:hover { color: var(--white); }
  .coaches--light .coach-card__more:hover { color: var(--navy-700); }
  .coach-card__more:focus-visible {
    outline: 2px solid var(--teal-500);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ----- in-section "see more" link ----- */
  .coaches__cta {
    margin-top: var(--space-10);
    text-align: center;
  }
  .coaches__cta-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }
  .coaches--dark .coaches__cta-link { color: var(--teal-400); }
  .coaches--light .coaches__cta-link { color: var(--teal-700); }
  .coaches__cta-link:hover {
    border-color: var(--teal-400);
  }
  .coaches--dark .coaches__cta-link:hover { color: var(--white); }
  .coaches--light .coaches__cta-link:hover { color: var(--navy-700); }

  /* ----- compact (homepage): chrome-less photo + name + role ----- */
  .coach-card--compact {
    background: transparent;
    border: none;
    box-shadow: none;
    border-radius: 0;
    overflow: visible;
  }
  .coaches--dark .coach-card--compact { background: transparent; }
  .coach-card--compact .coach-card__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .coach-card--compact .coach-card__body {
    padding: var(--space-4) 0 0;
    gap: var(--space-1);
  }

  /* ============================ bio dialog ============================ */
  .coach-dialog {
    width: min(640px, calc(100vw - 2 * var(--space-4)));
    max-height: min(86vh, 760px);
    padding: 0;
    border: none;
    border-radius: var(--r-lg);
    background: var(--surface);
    color: var(--text-body);
    box-shadow: var(--shadow-lg, 0 24px 60px rgba(11, 22, 44, 0.35));
    overflow: hidden;
  }
  .coach-dialog::backdrop {
    background: rgba(9, 18, 38, 0.62);
    backdrop-filter: blur(2px);
  }
  .coach-dialog[open] {
    animation: coach-dialog-in var(--dur-base, 200ms) var(--ease-out, ease-out);
  }
  @keyframes coach-dialog-in {
    from { opacity: 0; transform: translateY(8px) scale(0.985); }
    to { opacity: 1; transform: none; }
  }

  .coach-dialog__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    max-height: inherit;
    overflow-y: auto;
  }

  .coach-dialog__close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--dur-base) var(--ease-out), background var(--dur-base) var(--ease-out);
  }
  .coach-dialog__close:hover { color: var(--navy-700); background: var(--surface-inset); }
  .coach-dialog__close:focus-visible { outline: 2px solid var(--teal-500); outline-offset: 2px; }

  .coach-dialog__header {
    display: flex;
    gap: var(--space-5);
    align-items: center;
    padding: var(--space-6);
    padding-right: calc(var(--space-6) + 44px);
    background: var(--navy-900);
    color: var(--text-on-dark);
  }
  .coach-dialog__media {
    flex: none;
    width: 96px;
    height: 96px;
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--navy-700);
  }
  .coach-dialog__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .coach-dialog__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy-900);
  }
  .coach-dialog__placeholder img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    opacity: 0.55;
  }
  .coach-dialog__placeholder .coach-card__initials { font-size: 34px; }

  .coach-dialog__ident { display: flex; flex-direction: column; gap: var(--space-2); }
  .coach-dialog__name {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: 26px;
    line-height: 1.05;
    margin: 0;
    color: var(--white);
  }
  .coach-dialog__role {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 13px;
    color: var(--teal-400);
  }
  .coach-dialog__badges { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-1); }

  .coach-dialog__body { padding: var(--space-6); }
  .coach-dialog__bio { font-size: 16px; line-height: 1.65; color: var(--text-body); }
  .coach-dialog__bio :global(p) { margin: 0 0 var(--space-4); }
  .coach-dialog__bio :global(p:last-child) { margin-bottom: 0; }

  .coach-dialog__highlights {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
