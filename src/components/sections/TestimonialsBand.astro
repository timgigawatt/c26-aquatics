---
/**
 * TestimonialsBand — two formats:
 *   variant="grid"    (default) 3-up quote cards on a paper background.
 *   variant="feature"           one dramatic centered pull-quote on a navy band.
 * Big stylized opening quote mark in teal; italic quote; author + role beneath.
 */
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  variant?: 'grid' | 'feature';
  featuredOnly?: boolean;
  eyebrow?: string;
  heading?: string;
  limit?: number;
}

const {
  variant = 'grid',
  featuredOnly = true,
  eyebrow = 'In their words',
  heading = 'Families who swim with us',
  limit,
} = Astro.props;

type TestimonialEntry = CollectionEntry<'testimonials'>;
const all = await getCollection('testimonials');
const filtered = featuredOnly
  ? all.filter((t: TestimonialEntry) => t.data.featured)
  : all;
const sorted = filtered.sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order,
);
const testimonials = typeof limit === 'number' ? sorted.slice(0, limit) : sorted;
const feature = testimonials[0];
---
{variant === 'feature' && feature ? (
  <section class="feature-quote" aria-labelledby="testimonials-title">
    <div class="container">
      <h2 id="testimonials-title" class="sr-only">{heading}</h2>
      <figure class="fq">
        <span class="fq__mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="fq__text">{feature.data.quote}</blockquote>
        <figcaption class="fq__cite">
          <span class="fq__author">{feature.data.author}</span>
          <span class="fq__role">{feature.data.role}</span>
        </figcaption>
      </figure>
    </div>
  </section>
) : (
  <section class="testimonials" aria-labelledby="testimonials-title">
    <div class="container">
      <header class="testimonials__head">
        {eyebrow && <p class="testimonials__eyebrow">{eyebrow}</p>}
        <h2 id="testimonials-title" class="testimonials__heading">{heading}</h2>
      </header>

      <div class="testimonials__grid">
        {testimonials.map((t: TestimonialEntry) => (
          <figure class="quote">
            <span class="quote__mark" aria-hidden="true">&ldquo;</span>
            <blockquote class="quote__text">{t.data.quote}</blockquote>
            <figcaption class="quote__cite">
              <span class="quote__author">{t.data.author}</span>
              <span class="quote__role">{t.data.role}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ---------- feature: single navy pull-quote ---------- */
  .feature-quote {
    background: var(--navy-700);
    color: var(--text-on-dark);
    padding: var(--section-y) 0;
  }
  .fq {
    margin: 0;
    max-width: 900px;
    margin-inline: auto;
    text-align: center;
    position: relative;
  }
  .fq__mark {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: clamp(72px, 12vw, 140px);
    line-height: 0.7;
    color: var(--teal-400);
    margin-bottom: var(--space-2);
    pointer-events: none;
  }
  .fq__text {
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.6vw, 44px);
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--white);
    text-wrap: balance;
  }
  .fq__cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: var(--space-6);
    font-style: normal;
  }
  .fq__author {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 15px;
    color: var(--teal-400);
  }
  .fq__role {
    font-size: 14px;
    color: var(--text-on-dark-muted);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- grid: 3-up paper cards ---------- */
  .testimonials {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .testimonials__head {
    max-width: 720px;
    margin-bottom: var(--space-10);
  }
  .testimonials__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .testimonials__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    color: var(--navy-700);
    margin: 0;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .quote {
    position: relative;
    margin: 0;
    padding: var(--space-8) var(--space-6) var(--space-6);
    background: var(--surface);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .quote__mark {
    position: absolute;
    top: -6px;
    left: var(--space-5);
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: 96px;
    line-height: 1;
    color: var(--teal-500);
    pointer-events: none;
  }
  .quote__text {
    margin: 0;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-strong);
  }
  .quote__cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
    margin-top: auto;
  }
  .quote__author {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--navy-700);
  }
  .quote__role {
    font-size: 13px;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>
