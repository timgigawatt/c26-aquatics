---
/**
 * TestimonialsBand — two formats:
 *   variant="grid"    (default) 3-up quote cards on a paper background.
 *   variant="feature"           an auto-rotating pull-quote on a navy band.
 *
 * Feature rotator: every featured quote is rendered in the DOM (crawlable, and
 * the first shows with no JS). A grid-stack overlaps the slides so height =
 * tallest quote; JS cross-fades between them, pauses on hover/focus, and honors
 * prefers-reduced-motion (no auto-advance; dot navigation still works).
 */
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  variant?: 'grid' | 'feature';
  featuredOnly?: boolean;
  eyebrow?: string;
  heading?: string;
  limit?: number;
}

const {
  variant = 'grid',
  featuredOnly = true,
  eyebrow = 'In their words',
  heading = 'Families who swim with us',
  limit,
} = Astro.props;

type TestimonialEntry = CollectionEntry<'testimonials'>;
const all = await getCollection('testimonials');
const filtered = featuredOnly
  ? all.filter((t: TestimonialEntry) => t.data.featured)
  : all;
const sorted = filtered.sort(
  (a: TestimonialEntry, b: TestimonialEntry) => a.data.order - b.data.order,
);
const testimonials = typeof limit === 'number' ? sorted.slice(0, limit) : sorted;
const hasFeature = testimonials.length > 0;
---
{variant === 'feature' && hasFeature ? (
  <section class="feature-quote" aria-labelledby="testimonials-title" data-testimonial-rotator>
    <div class="container">
      <h2 id="testimonials-title" class="sr-only">{heading}</h2>
      <div class="fq-stack">
        {testimonials.map((t: TestimonialEntry, i: number) => (
          <figure class="fq" data-slide data-active={i === 0 ? 'true' : 'false'} aria-hidden={i === 0 ? undefined : 'true'}>
            <span class="fq__mark" aria-hidden="true">&ldquo;</span>
            <blockquote class="fq__text">{t.data.quote}</blockquote>
            <figcaption class="fq__cite">
              <span class="fq__author">{t.data.author}</span>
              <span class="fq__role">{t.data.role}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      {testimonials.length > 1 && (
        <div class="fq-dots" role="tablist" aria-label="Choose a testimonial">
          {testimonials.map((t: TestimonialEntry, i: number) => (
            <button
              type="button"
              role="tab"
              class="fq-dot"
              data-dot={i}
              aria-selected={i === 0 ? 'true' : 'false'}
              tabindex={i === 0 ? 0 : -1}
              aria-label={`Show testimonial ${i + 1} of ${testimonials.length}`}
            ></button>
          ))}
        </div>
      )}
    </div>
  </section>
) : (
  <section class="testimonials" aria-labelledby="testimonials-title">
    <div class="container">
      <header class="testimonials__head">
        {eyebrow && <p class="testimonials__eyebrow">{eyebrow}</p>}
        <h2 id="testimonials-title" class="testimonials__heading">{heading}</h2>
      </header>

      <div class="testimonials__grid">
        {testimonials.map((t: TestimonialEntry) => (
          <figure class="quote">
            <span class="quote__mark" aria-hidden="true">&ldquo;</span>
            <blockquote class="quote__text">{t.data.quote}</blockquote>
            <figcaption class="quote__cite">
              <span class="quote__author">{t.data.author}</span>
              <span class="quote__role">{t.data.role}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<script>
  function initRotator(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot]'));
    if (slides.length < 2) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Sequential fade: the current quote fades out, then the next fades in.
    // Must match the CSS opacity transition on `.fq`.
    const FADE_MS = 450;
    let index = 0;
    let timer: number | undefined;
    let fadeTimer: number | undefined;

    const show = (next: number) => {
      const target = (next + slides.length) % slides.length;
      if (target === index) return;
      index = target;

      // Move dot selection immediately so the control feels responsive.
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
        dot.tabIndex = active ? 0 : -1;
      });

      // Fade out whatever is currently showing.
      slides.forEach((slide, i) => {
        if (i !== index && slide.dataset.active === 'true') {
          slide.dataset.active = 'false';
          slide.setAttribute('aria-hidden', 'true');
        }
      });

      const reveal = () => {
        slides[index].dataset.active = 'true';
        slides[index].removeAttribute('aria-hidden');
      };

      window.clearTimeout(fadeTimer);
      if (reduce) {
        reveal();
      } else {
        // Wait for the fade-out to finish before fading the next one in.
        fadeTimer = window.setTimeout(reveal, FADE_MS);
      }
    };

    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(() => show(index + 1), 6500);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        show(i);
        start();
      });
      dot.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          show(index + 1);
          dots[index].focus();
          start();
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          show(index - 1);
          dots[index].focus();
          start();
        }
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);

    start();
  }

  document
    .querySelectorAll<HTMLElement>('[data-testimonial-rotator]')
    .forEach((el) => initRotator(el));
</script>

<style>
  /* ---------- feature: rotating navy pull-quote ---------- */
  .feature-quote {
    background: var(--navy-700);
    color: var(--text-on-dark);
    /* Hairline defines the seam against the darker CoachesGrid above. */
    border-top: 1px solid var(--border-on-dark);
    padding: var(--section-y) 0;
  }
  .fq-stack {
    display: grid;
    max-width: 900px;
    margin-inline: auto;
  }
  .fq {
    grid-area: 1 / 1;
    margin: 0;
    text-align: center;
    position: relative;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 450ms var(--ease-out), visibility 0s linear 450ms;
  }
  .fq[data-active='true'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 450ms var(--ease-out);
  }
  .fq__mark {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: clamp(72px, 12vw, 140px);
    line-height: 0.7;
    color: var(--teal-400);
    margin-bottom: var(--space-2);
    pointer-events: none;
  }
  .fq__text {
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.6vw, 44px);
    line-height: 1.1;
    letter-spacing: var(--ls-tight);
    color: var(--white);
    text-wrap: balance;
  }
  .fq__cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: var(--space-6);
    font-style: normal;
  }
  .fq__author {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 15px;
    color: var(--teal-400);
  }
  .fq__role {
    font-size: 14px;
    color: var(--text-on-dark-muted);
  }

  .fq-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .fq-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border-radius: var(--r-pill);
    border: 1px solid var(--teal-400);
    background: transparent;
    cursor: pointer;
    transition: background var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
  }
  .fq-dot:hover { background: rgba(255, 255, 255, 0.25); }
  .fq-dot[aria-selected='true'] {
    background: var(--teal-400);
    transform: scale(1.15);
  }
  .fq-dot:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .fq { transition: none; }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- grid: 3-up paper cards ---------- */
  .testimonials {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .testimonials__head {
    max-width: 720px;
    margin-bottom: var(--space-10);
  }
  .testimonials__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .testimonials__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    color: var(--navy-700);
    margin: 0;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .quote {
    position: relative;
    margin: 0;
    padding: var(--space-8) var(--space-6) var(--space-6);
    background: var(--surface);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .quote__mark {
    position: absolute;
    top: -6px;
    left: var(--space-5);
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: 96px;
    line-height: 1;
    color: var(--teal-500);
    pointer-events: none;
  }
  .quote__text {
    margin: 0;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-strong);
  }
  .quote__cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
    margin-top: auto;
  }
  .quote__author {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--navy-700);
  }
  .quote__role {
    font-size: 13px;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .testimonials__grid { grid-template-columns: 1fr; }
  }
</style>
