---
/**
 * MissionBand — white 2-column story band: eyebrow + heading + two paragraphs on
 * the left, a 4:5 founders/story photo on the right. Sits between StatsBand and
 * DifferenceBand on the homepage.
 *
 * No real founders photo yet — pass `image` (a runtime path under /public) to use
 * one; otherwise we render a branded kraken placeholder so the section ships.
 */
import krakenWhite from '@assets/brand/kraken-white.svg';

interface Props {
  eyebrow?: string;
  heading?: string;
  paragraphs?: string[];
  /** Optional inline text link rendered under the paragraphs. */
  cta?: { label: string; href: string };
  /** Runtime path (under /public) to the founders/story photo, 4:5. */
  image?: string;
  imageAlt?: string;
}

const {
  eyebrow = 'Our mission',
  heading = 'Stronger swimmers, for life',
  paragraphs = [
    'C26 Aquatics exists to build confident, capable swimmers — and to keep them in the water for life, from a child’s first lesson to an adult’s first triathlon.',
    'We started C26 because we were tired of crowded rec programs and a new instructor every session. So we built a single home for swimming in Kansas City: one pool, one coaching staff, one standard.',
  ],
  cta,
  image,
  imageAlt = 'The C26 Aquatics founders on deck',
} = Astro.props;
---
<section class="mission" aria-labelledby="mission-title">
  <div class="container mission__inner">
    <div class="mission__copy">
      <p class="mission__eyebrow">{eyebrow}</p>
      <h2 id="mission-title" class="mission__heading">{heading}</h2>
      {paragraphs.map((p) => <p class="mission__para">{p}</p>)}
      {cta && (
        <a href={cta.href} class="mission__cta">
          {cta.label}
          <span aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>

    <div class="mission__media">
      {image ? (
        <img
          class="mission__photo"
          src={image}
          alt={imageAlt}
          width="640"
          height="800"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="mission__placeholder" role="img" aria-label="Founders / story photo — coming soon">
          <img
            src={krakenWhite.src}
            alt=""
            class="mission__placeholder-kraken"
            loading="lazy"
          />
          <span class="mission__placeholder-label">Founders / story photo</span>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .mission {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .mission__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: clamp(32px, 6vw, 80px);
  }

  .mission__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .mission__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-5);
  }
  .mission__para {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0 0 var(--space-4);
    max-width: 52ch;
  }
  .mission__para:last-child { margin-bottom: 0; }
  .mission__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-600);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: color var(--dur-base) var(--ease-out), border-color var(--dur-base) var(--ease-out);
  }
  .mission__cta:hover {
    color: var(--navy-700);
    border-color: var(--teal-600);
  }

  .mission__media {
    aspect-ratio: 4 / 5;
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .mission__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mission__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--navy-700) 0%, var(--navy-900) 100%);
    overflow: hidden;
  }
  .mission__placeholder-kraken {
    width: 62%;
    height: auto;
    opacity: 0.16;
  }
  .mission__placeholder-label {
    position: absolute;
    bottom: var(--space-4);
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--text-on-dark-muted);
  }

  @media (max-width: 800px) {
    .mission__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .mission__media {
      max-width: 360px;
    }
  }
</style>
