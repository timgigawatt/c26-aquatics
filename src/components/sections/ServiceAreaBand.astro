---
/**
 * ServiceAreaBand — light mist band of readable text chips (KC-metro cities,
 * coaching-system keywords…). Renders CMS `chipsBand` blocks. Chips must be
 * plain DOM text (not images) for local SEO.
 */
import Badge from '@components/ui/Badge.astro';

interface Props {
  heading?: string;
  subtitle?: string;
  chips: { text: string; note?: string }[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading,
  subtitle,
  chips,
  ctaLabel,
  ctaHref,
} = Astro.props;
---
<section id="service-area" class="service" aria-labelledby="service-title">
  <div class="container service__inner">
    <header class="service__head">
      <h2 id="service-title" class="service__heading">{heading}</h2>
      {subtitle && <p class="service__subtitle">{subtitle}</p>}
    </header>

    <ul class="service__cities">
      {chips.map((chip) => (
        <li>
          <Badge tone="outline" size="md">
            {chip.text}{chip.note ? `, ${chip.note}` : ''}
          </Badge>
        </li>
      ))}
    </ul>

    {ctaLabel && ctaHref && (
      <a href={ctaHref} class="service__cta">
        {ctaLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    )}
  </div>
</section>

<style>
  .service {
    background: var(--surface-inset);
    color: var(--text-body);
    padding: var(--section-y-tight) 0;
  }
  .service__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .service__head {
    max-width: 760px;
  }
  .service__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.4vw, 38px);
    color: var(--navy-700);
    margin: 0;
  }
  .service__subtitle {
    color: var(--text-muted);
    margin: var(--space-3) 0 0;
    font-size: 17px;
    line-height: 1.55;
  }
  .service__cities {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .service__cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color var(--dur-base) var(--ease-out), color var(--dur-base) var(--ease-out);
  }
  .service__cta:hover {
    color: var(--navy-700);
    border-color: var(--teal-500);
  }
</style>
