---
/**
 * RichTextSection — renders CMS `richText` blocks. Picks a treatment from the
 * block's structure:
 *   - with image        → 2-column feature band (photo left or right)
 *   - short bare line   → navy display band (pullquotes, mottos)
 *   - otherwise         → prose section (story, statements, evaluations…)
 *
 * `body` is markdown; blank lines separate paragraphs.
 */
import { micromark } from 'micromark';
import Button from '@components/ui/Button.astro';

interface Props {
  id?: string;
  eyebrow?: string;
  heading?: string;
  body: string;
  imageUrl?: string;
  imageAlt?: string;
  imagePosition?: 'left' | 'right';
  buttons?: { label: string; href: string; style?: string }[];
}

const { id, eyebrow, heading, body, imageUrl, imageAlt, imagePosition = 'left', buttons = [] } = Astro.props;

const isDisplay = !imageUrl && !heading && !body.includes('\n') && body.length <= 140;
const html = micromark(body);
const external = (href: string) => href.startsWith('http');
---
{isDisplay ? (
  <section id={id} class="rt-display" aria-label={body}>
    <div class="container">
      <p class="rt-display__text">{body}</p>
    </div>
  </section>
) : imageUrl ? (
  <section id={id} class:list={['rt-feature', `rt-feature--${imagePosition}`]}>
    <div class="container rt-feature__inner">
      <div class="rt-feature__copy">
        {eyebrow && <p class="rt__eyebrow">{eyebrow}</p>}
        {heading && <h2 class="rt__heading">{heading}</h2>}
        <div class="rt__prose" set:html={html} />
        {buttons.length > 0 && (
          <div class="rt__actions">
            {buttons.map((b) =>
              b.style === 'accent' ? (
                <Button href={b.href} variant="primary" external={external(b.href)}>{b.label}</Button>
              ) : (
                <a class="rt__link" href={b.href}>{b.label} <span aria-hidden="true">&rarr;</span></a>
              ),
            )}
          </div>
        )}
      </div>
      <div class="rt-feature__media">
        <img src={imageUrl} alt={imageAlt ?? ''} loading="lazy" decoding="async" />
      </div>
    </div>
  </section>
) : (
  <section id={id} class="rt-prose">
    <div class="container rt-prose__inner">
      {eyebrow && <p class="rt__eyebrow">{eyebrow}</p>}
      {heading && <h2 class="rt__heading">{heading}</h2>}
      <div class="rt__prose" set:html={html} />
      {buttons.length > 0 && (
        <div class="rt__actions">
          {buttons.map((b) =>
            b.style === 'accent' ? (
              <Button href={b.href} variant="primary" external={external(b.href)}>{b.label}</Button>
            ) : (
              <a class="rt__link" href={b.href}>{b.label} <span aria-hidden="true">&rarr;</span></a>
            ),
          )}
        </div>
      )}
    </div>
  </section>
)}

<style>
  .rt__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .rt__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.4vw, 38px);
    color: var(--navy-700);
    margin: 0 0 var(--space-4);
  }
  .rt__prose :global(p) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-body);
    margin: 0 0 var(--space-4);
  }
  .rt__prose :global(ul) {
    margin: 0 0 var(--space-4);
    padding-left: 1.2em;
  }
  .rt__prose :global(li) {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-body);
    margin-bottom: var(--space-2);
  }
  .rt__prose :global(a) {
    color: var(--teal-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rt__prose :global(strong) {
    color: var(--navy-700);
  }
  .rt__actions {
    margin-top: var(--space-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }
  .rt__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
  }
  .rt__link:hover {
    color: var(--navy-700);
  }

  .rt-prose {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .rt-prose__inner {
    max-width: 780px;
  }

  .rt-display {
    background: var(--navy-900);
    color: var(--text-on-dark);
    padding: var(--section-y) 0;
  }
  .rt-display__text {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    text-transform: uppercase;
    font-size: clamp(26px, 4.2vw, 48px);
    line-height: 1.12;
    letter-spacing: var(--ls-tight);
    color: var(--white);
  }

  .rt-feature {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .rt-feature__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: center;
  }
  .rt-feature--left .rt-feature__media {
    order: -1;
  }
  .rt-feature__media img {
    width: 100%;
    height: auto;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-md, 0 12px 32px rgba(11, 22, 44, 0.16));
  }
  @media (max-width: 800px) {
    .rt-feature__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .rt-feature--left .rt-feature__media {
      order: 0;
    }
  }
</style>
