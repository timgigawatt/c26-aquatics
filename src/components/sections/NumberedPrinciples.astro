---
/**
 * NumberedPrinciples — big-number principle cards (2 columns on desktop,
 * single column under ~860px). Used for the four commitments of the C26
 * method and the six-item C26 coaching system on /our-approach. Data from
 * src/data/approach.ts. Number accents alternate teal/orange by row pair
 * (01/02 teal, 03/04 orange, 05/06 teal, …).
 *
 * `intro` accepts a string or string[] (rendered as separate paragraphs);
 * an optional named `outro` slot renders below the grid.
 */
import { principles, type Principle } from '@data/approach';

interface Props {
  /** Anchor id for deep links; also namespaces the heading id. */
  id?: string;
  eyebrow?: string;
  heading?: string;
  intro?: string | string[];
  items?: Principle[];
  /** 'alt' renders on var(--surface-alt) instead of var(--surface). */
  tone?: 'default' | 'alt';
}

const {
  id,
  eyebrow = 'The C26 method',
  heading = 'Train with purpose',
  intro = 'Every practice has a purpose. Every set has an objective. Every season has a plan. Our whole philosophy comes down to four commitments we make to every swimmer.',
  items = principles,
  tone = 'default',
} = Astro.props;

const introParas = Array.isArray(intro) ? intro : [intro];
const headingId = id ? `${id}-title` : 'principles-title';
---
<section
  id={id}
  class:list={['principles', { 'principles--alt': tone === 'alt' }]}
  aria-labelledby={headingId}
>
  <div class="container">
    <p class="principles__eyebrow">{eyebrow}</p>
    <h2 id={headingId} class="principles__heading">{heading}</h2>
    {introParas.map((p) => (
      <p class="principles__intro">{p}</p>
    ))}

    <ul class="principles__grid">
      {items.map((p, i) => (
        <li class="principle" data-accent={Math.floor(i / 2) % 2 === 0 ? 'teal' : 'orange'}>
          <span class="principle__num" aria-hidden="true">{p.n}</span>
          <div class="principle__body">
            <h3 class="principle__title">{p.title}</h3>
            <p class="principle__text">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>

    {Astro.slots.has('outro') && (
      <div class="principles__outro">
        <slot name="outro" />
      </div>
    )}
  </div>
</section>

<style>
  .principles {
    background: var(--surface);
    padding: var(--section-y) 0;
    scroll-margin-top: 96px;
  }
  .principles--alt {
    background: var(--surface-alt);
  }
  .principles__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .principles__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-4);
  }
  .principles__intro {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0;
    max-width: 680px;
  }
  .principles__intro + .principles__intro {
    margin-top: var(--space-3);
  }

  .principles__outro {
    margin-top: 56px;
  }

  .principles__grid {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 44px 56px;
  }
  .principle {
    display: flex;
    gap: 22px;
  }
  .principle__num {
    flex: none;
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    font-size: 64px;
    line-height: 0.8;
    color: var(--teal-400);
  }
  .principle[data-accent='orange'] .principle__num {
    color: var(--orange-500);
  }
  .principle__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: 24px;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-2);
  }
  .principle__text {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0;
  }

  @media (max-width: 860px) {
    .principles__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
