---
/**
 * LocationBand — paper 2-column "single home" band: address + hours on the left,
 * a facility photo (placeholder for now) on the right. Distinct job from
 * ServiceAreaBand, which lists KC-metro cities as crawlable text for local SEO.
 *
 * Address/hours fall back to wire placeholders — `site.address.streetAddress` is
 * still a TODO. Wire real values through props (or fill in site.ts) before launch.
 */
import { Image } from 'astro:assets';
import krakenNavy from '@assets/brand/kraken-navy.png';
import { site } from '@data/site';

interface Props {
  eyebrow?: string;
  heading?: string;
  blurb?: string;
  address?: string;
  hours?: string;
  /** Runtime path (under /public) to a facility / exterior photo. */
  image?: string;
  imageAlt?: string;
}

const a = site.address;
const composedAddress = a.streetAddress
  ? `${a.streetAddress}, ${a.addressLocality}, ${a.addressRegion} ${a.postalCode}`
  : '0000 Example Pkwy, Overland Park, KS 66200';

const {
  eyebrow = 'Our home',
  heading = 'One pool. One standard.',
  blurb = 'Everything happens under one roof — no satellites, no rotating rental lanes. Every swimmer trains in the same water with the same staff.',
  address = composedAddress,
  hours = 'Mon–Sat · 6am – 9pm',
  image,
  imageAlt = 'The C26 Aquatics facility',
} = Astro.props;
---
<section class="location" aria-labelledby="location-title">
  <div class="container location__inner">
    <div class="location__copy">
      <p class="location__eyebrow">{eyebrow}</p>
      <h2 id="location-title" class="location__heading">{heading}</h2>
      <p class="location__blurb">{blurb}</p>

      <dl class="location__facts">
        <div class="location__fact">
          <dt>Address</dt>
          <dd>{address}</dd>
        </div>
        <div class="location__fact">
          <dt>Hours</dt>
          <dd>{hours}</dd>
        </div>
      </dl>
    </div>

    <div class="location__media">
      {image ? (
        <img
          class="location__photo"
          src={image}
          alt={imageAlt}
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="location__placeholder" role="img" aria-label="Facility map / exterior photo — coming soon">
          <Image
            src={krakenNavy}
            alt=""
            class="location__placeholder-kraken"
            widths={[320, 480]}
            sizes="(max-width: 800px) 60vw, 40vw"
            loading="lazy"
          />
          <span class="location__placeholder-label">Facility map / exterior</span>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .location {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .location__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(32px, 6vw, 80px);
  }

  .location__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .location__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-4);
  }
  .location__blurb {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0 0 var(--space-6);
    max-width: 52ch;
  }

  .location__facts {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .location__fact {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
  }
  .location__fact dt {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--teal-700);
  }
  .location__fact dd {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-strong);
  }

  .location__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .location__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .location__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--mist) 0%, var(--surface-inset) 100%);
    overflow: hidden;
  }
  .location__placeholder-kraken {
    width: 46%;
    height: auto;
    opacity: 0.12;
  }
  .location__placeholder-label {
    position: absolute;
    bottom: var(--space-4);
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 800px) {
    .location__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
