# Gigawatt CMS credentials — required for `npm run build` and `npm run seed:cms`.
# The build authenticates as the c26 client-editor so every read is scoped to
# the c26 tenant. Copy to .env and fill in; never commit real values.
CMS_URL=https://gigawatt-cms--gigawatt-lab.us-central1.hosted.app
CMS_EMAIL=editor@c26.com
CMS_PASSWORD=
